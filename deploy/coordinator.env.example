# Copy to /opt/ocp/config/coordinator.env on the VPS.
# Required in production:
# - COORDINATOR_WRITE_TOKEN
# Optional:
# - CORS_ORIGINS

# Comma-separated allowlist (no wildcard recommended in production).
# Example: CORS_ORIGINS=https://discordwell.com
CORS_ORIGINS=https://discordwell.com

# Required when COORDINATOR_REQUIRE_WRITE_AUTH=true.
# Generate with:
#   openssl rand -hex 32
COORDINATOR_WRITE_TOKEN=replace-with-random-token

# Optional overrides (defaults are set in systemd unit).
# COORDINATOR_CHAIN_ADAPTER=cosmos
# COORDINATOR_COSMOS_RPC_URL=http://127.0.0.1:26657
# COORDINATOR_COSMOS_LCD_URL=http://127.0.0.1:1317

# Reverse-proxy hops in front of the coordinator, used to read the real client
# IP from X-Forwarded-For for rate limiting. Default 1 matches deploy/nginx-ocp.conf
# (a single nginx that appends the peer address). Set higher if you add another
# proxy (e.g. a CDN) in front, or 0 if the coordinator is exposed directly.
# COORDINATOR_TRUSTED_PROXY_HOPS=1

# Faucet — dispenses testnet CHIPS to users.
FAUCET_ENABLED=true
FAUCET_MNEMONIC=replace-with-faucet-mnemonic
FAUCET_AMOUNT=5000000
# FAUCET_DENOM=uchips
# FAUCET_COOLDOWN_SECS=3600
# FAUCET_IP_COOLDOWN_SECS=600
